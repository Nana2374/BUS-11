  m_Script: {fileID: 11500000, guid: 05e9573c6467e754e97a0e7e8baf0ff4, type: 3}
  m_Name: BS_9_ElderlyWoman
  m_EditorClassIdentifier: 
  nodes:
  - nodeID: 0
    branchType: 0
    dialogueLine: Oh good, you stopped. I thought you were going to drive past.
    speaker: 11
    nextNodeIndex: 1
    choices: []
  - nodeID: 1
    branchType: 0
    dialogueLine: The driver before you always did that, like he's afraid of letting
      people board.
    speaker: 11
    nextNodeIndex: 2
    choices: []
  - nodeID: 2
    branchType: 0
    dialogueLine: But I don't blame him... I wouldn't dare let some things in either.
    speaker: 11
    nextNodeIndex: 3
    choices: []
  - nodeID: 3
    branchType: 0
    dialogueLine: Sorry, did I frighten you? You look rather pale.
    speaker: 11
    nextNodeIndex: -1
    choices:
    - choiceText: Am I tripping?
      nextNodeIndex: 4
    - choiceText: I saw you!
      nextNodeIndex: 5
  - nodeID: 4
    branchType: 1
    dialogueLine: Am I tripping, or did you board the bus earlier? You are saying
      the same thing...
    speaker: 0
    nextNodeIndex: 6
    choices: []
  - nodeID: 5
    branchType: 2
    dialogueLine: W-weren't you here earlier? You even said the same thing!
    speaker: 0
    nextNodeIndex: 6
    choices: []
  - nodeID: 6
    branchType: 0
    dialogueLine: What? I don't understand you.
    speaker: 11
    nextNodeIndex: 6
    choices:
    - choiceText: Sorry.
      nextNodeIndex: 7
    - choiceText: It was you!
      nextNodeIndex: 8
  - nodeID: 7
    branchType: 1
    dialogueLine: Sorry. It must be my imagination...
    speaker: 0
    nextNodeIndex: 9
    choices: []
  - nodeID: 8
    branchType: 2
    dialogueLine: Really! Maybe you have a twin?
    speaker: 0
    nextNodeIndex: 9
    choices: []
  - nodeID: 9
    branchType: 2
    dialogueLine: You dont seem right. I hope you dont end up like the last one.
    speaker: 11
    nextNodeIndex: 10
    choices: []
